# ─────────────────────────────────────────
# Django Core
# ─────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────
# Local dev:  mongodb://localhost:27017
# Atlas:      mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_HOST=mongodb://localhost:27017
MONGODB_DB=ragchatbot

# ─────────────────────────────────────────
# CORS / CSRF  (add your deployed frontend URL in production)
# ─────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# In production set this to your Vercel + Render URLs, e.g.
# CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app,https://*.onrender.com
CSRF_TRUSTED_ORIGINS=https://*.onrender.com

# ─────────────────────────────────────────
# Groq LLM (primary)
# ─────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
# Lower output cap = fewer tokens per call = more messages fit Groq's TPM budget.
GROQ_MAX_OUTPUT_TOKENS=1024
GROQ_TEMPERATURE=0.2

# ─────────────────────────────────────────
# Gemini (OCR fallback only)
# ─────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_TEMPERATURE=0.2

# ─────────────────────────────────────────
# Persistent storage (optional)
# ─────────────────────────────────────────
# On Render's FREE tier the disk is wiped on every deploy/restart, so uploaded
# files + FAISS indexes do NOT persist. Add a Render Disk (paid) mounted at e.g.
# /data and set VOLUME_PATH=/data to keep media/ and indexes/ across restarts.
# VOLUME_PATH=/data

# ─────────────────────────────────────────
# Embeddings
# ─────────────────────────────────────────
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ─────────────────────────────────────────
# RAG Pipeline
# ─────────────────────────────────────────
# Chunking is CHARACTER-based (700-1000 recommended).
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=200
# Retrieval: MMR over a fetch_k candidate pool -> top_k chunks.
RAG_TOP_K=4
RAG_FETCH_K=20
RAG_USE_MMR=True
RAG_MMR_LAMBDA=0.7
# Low floor; the grounding prompt decides true relevance.
RAG_MIN_SIMILARITY_SCORE=0.2
# Set True to return retrieved-chunk diagnostics in the chat API response.
RAG_DEBUG=False
CONVERSATION_MEMORY_TURNS=5
# Per-user rate limit on the chat endpoint (DRF format: "<count>/<period>").
CHAT_THROTTLE_RATE=20/min

# ─────────────────────────────────────────
# File Upload
# ─────────────────────────────────────────
MAX_DOCUMENT_SIZE_MB=50

# ─────────────────────────────────────────
# Logging
# ─────────────────────────────────────────
DJANGO_LOG_LEVEL=INFO
